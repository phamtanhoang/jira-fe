# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — app won't talk to BE without this
# ─────────────────────────────────────────────────────────────────────────────
# Backend base URL. Next rewrites `/api/*` → `${NEXT_PUBLIC_API_URL}/*`.
# Default if missing: http://localhost:4000 (see src/lib/constants/env.ts).
NEXT_PUBLIC_API_URL=http://localhost:3031

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Sentry (runtime error tracking)
# ─────────────────────────────────────────────────────────────────────────────
# Browser + server runtime DSN. When empty, Sentry init is a no-op everywhere
# (also no-op in dev even if set — see instrumentation*.ts). Safe to leave on.
NEXT_PUBLIC_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Sentry build plugin (source map upload during `next build`)
# Used ONLY by @sentry/nextjs at build time, not by app code at runtime.
# Leave blank in dev — only matters for production builds.
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
